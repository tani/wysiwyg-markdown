{
  "name": "wysiwyg-markdown",
  "displayName": "WYSIWYG Markdown",
  "description": "A graphical editor for Markdown",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "browser": "./dist/web/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "wysiwyg-markdown.vditor",
        "displayName": "Vditor Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "test": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/extensionTests.js",
    "pretest": "bun run compile-web",
    "vscode:prepublish": "bun run package-web",
    "compile-web": "bun run check-types && bun run lint && bun esbuild.js",
    "watch-web": "npm-run-all -p watch-web:*",
    "watch-web:esbuild": "bun esbuild.js --watch",
    "watch-web:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package-web": "bun run check-types && bun run lint && bun esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/assert": "^1.5.11",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.56.1",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "@vscode/test-web": "^0.0.80",
    "esbuild": "^0.27.3",
    "glob": "^13.0.6",
    "npm-run-all": "^4.1.5",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "assert": "^2.1.0"
  },
  "dependencies": {
    "vditor": "^3.11.2"
  }
}
